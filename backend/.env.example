# ============================================================
# Vantage Backend — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ------------------------------------------------------------
# Application
# ------------------------------------------------------------

# Application display name (informational only)
APP_NAME=Vantage

# Semver string shown in /docs and health-check response
APP_VERSION=0.1.0

# URL prefix for all v1 API routes
API_V1_PREFIX=/api/v1

# ------------------------------------------------------------
# CORS
# ------------------------------------------------------------

# Comma-separated JSON list of frontend origins allowed to call the API.
# Vite dev server default is 5173; CRA default is 3000.
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ------------------------------------------------------------
# Logging
# ------------------------------------------------------------

# Python logging level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# ------------------------------------------------------------
# Ollama — Local LLM Server (Phase 3)
# ------------------------------------------------------------

# Base URL of the running Ollama instance.
# Use http://localhost:11434 for local dev.
# Use http://ollama:11434 when running inside Docker Compose.
OLLAMA_BASE_URL=http://localhost:11434

# Name of the model loaded in Ollama.
# Set to the alias you created when importing the .gguf file.
# Example: ollama create vantage-fin -f ./Modelfile
OLLAMA_MODEL=vantage-fin

# Max seconds to wait for an Ollama inference response before timing out.
OLLAMA_TIMEOUT_SECONDS=60

# Number of retry attempts on transient Ollama connection failures.
OLLAMA_MAX_RETRIES=2

# ------------------------------------------------------------
# Risk Thresholds (Phase 2)
# ------------------------------------------------------------

# Annualized volatility above this value (combined with low sentiment)
# triggers a risk rejection. Example: 0.40 = 40% annualized volatility.
VOLATILITY_THRESHOLD=0.40

# Sentiment score below this value (combined with high vol) triggers rejection.
# Range: -1.0 (very negative) to 1.0 (very positive)
SENTIMENT_REJECTION_THRESHOLD=0.2
